# ──── MongoDB ────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# ──── JWT ────
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=8h

# ──── Server ────
PORT=5000

# ──── Campus GPS Geofence ────
CAMPUS_LAT=12.962763
CAMPUS_LON=80.059258
CAMPUS_RADIUS=150

# ──── WebAuthn / FIDO2 ────
RP_ID=your-domain.com
RP_NAME=AttendGuard
ORIGIN=https://your-domain.com

# ──── CORS (comma-separated allowed origins) ────
ALLOWED_ORIGINS=https://your-frontend.github.io,https://your-domain.com,http://localhost:5173
